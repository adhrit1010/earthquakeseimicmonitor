# TriAxis Dynamic Website Backend

PORT=8787

# Supabase Project Settings -> API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Optional but recommended for backend-only Supabase reads.
# Never put this in browser HTML.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Google Gemini API key for the AI station analyst (the backend calls the
# Gemini Generative Language API). If omitted, it uses the built-in local
# deterministic analyst instead. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

